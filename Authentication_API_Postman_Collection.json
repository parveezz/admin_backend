		{
			"name": "Authentication",
			"item": [
				{
					"name": "Register User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response.success && response.token) {",
									"    pm.collectionVariables.set(\"token\", response.token);",
									"    console.log(\"Auth token automatically saved to collection variable 'token'\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"fullName\": \"John Doe\",\n  \"emailAddress\": \"johndoe@example.com\",\n  \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/auth/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"register"
							]
						},
						"description": "Registers a new user account. On a successful registration, it automatically saves the returned JWT token to the `token` collection variable."
					},
					"response": []
				},
				{
					"name": "Login User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (response.success) {",
									"    if (response.require2FA) {",
									"        pm.collectionVariables.set(\"temp_token\", response.tempToken);",
									"        console.log(\"2FA verification required. tempToken saved to 'temp_token'\");",
									"    } else if (response.token) {",
									"        pm.collectionVariables.set(\"token\", response.token);",
									"        console.log(\"Auth token automatically saved to collection variable 'token'\");",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"emailAddress\": \"johndoe@example.com\",\n  \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"login"
							]
						},
						"description": "Authenticates a user. If 2FA is active, returns a `tempToken` to verify code. If not, the returned JWT token is stored in the `token` collection variable and a refresh cookie is issued."
					},
					"response": []
				},
